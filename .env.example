DATABASE_URL="file:./data/dev.db"
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Set to "true" only when you need to create a new account; disable after initial setup
REGISTRATION_ENABLED="true"
# Upstash Redis for rate limiting on auth endpoints (optional in dev, required in production)
# Get credentials at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
