# Neon PostgreSQL connection string (use the pooled -pooler URL from Neon dashboard)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Set to "true" only when you need to create a new account; disable after initial setup
REGISTRATION_ENABLED="true"
# Upstash Redis for rate limiting on auth endpoints (optional in dev, required in production)
# Get credentials at upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
